# Don't commit personal context — this is your private data
context-library/couple-profile.md
context-library/preferences.md
context-library/financials.md
context-library/constraints.md
context-library/local-context.md
context-library/memory/*.md

# DO track templates (these ship with the repo for new users)
!context-library/*.template.md
!context-library/memory/*.template.md

# Keep templates but not filled outputs (optional — remove if you want to commit outputs)
outputs/dates/*.md
outputs/trips/*.md
outputs/activities/*.md
outputs/check-ins/*.md
outputs/letters/*.md
outputs/surprises/*.md
outputs/suggestion-log.md

# Keep .gitkeep files so directories exist
!outputs/**/.gitkeep

# System files
.DS_Store
Thumbs.db
*.swp
